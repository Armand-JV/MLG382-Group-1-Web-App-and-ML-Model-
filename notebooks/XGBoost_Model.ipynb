   "source": [
    "df = load_data()\n",
    "result = run_pipeline(df)\n",
    "\n",
    "X_train_proc  = result['X_train']\n",
    "X_test_proc   = result['X_test']\n",
    "y_train       = result['y_train']\n",
    "y_test        = result['y_test']\n",
    "preprocessor  = result['preprocessor']\n",
    "label_encoder = result['label_encoder']\n",
    "feature_names = result['feature_names']\n",
    "\n",
    "classes   = list(label_encoder.classes_)\n",
    "n_classes = len(classes)\n",
    "\n",
    "print(f'Train shape : {X_train_proc.shape}')\n",
    "print(f'Test shape  : {X_test_proc.shape}')\n",
    "print(f'Classes ({n_classes}): {classes}')\n",
    "print(f'\\nClass distribution in training set:')\n",
    "for i, cls in enumerate(classes):\n",
    "    print(f'  {cls}: {np.sum(y_train == i)} ({np.sum(y_train == i)/len(y_train):.2%})')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "xgb-weights-md",
   "metadata": {},
   "source": [
    "### Class Imbalance — Sample Weights\n",
    "XGBoost requires manual sample weights for multi-class imbalance handling."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "xgb-weights",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training class counts:\n",
      "  Gestational: 117 (0.31%)\n",
      "  No Diabetes: 2968 (7.93%)\n",
      "  Pre-Diabetes: 11880 (31.75%)\n",
      "  Type 1: 50 (0.13%)\n",
      "  Type 2: 22402 (59.87%)\n"
     ]
    }
   ],
   "source": [
    "sample_weights = compute_sample_weight(class_weight='balanced', y=y_train)\n",
    "\n",
    "class_counts = np.bincount(y_train)\n",
    "print('Training class counts:')\n",
    "for i, cls in enumerate(classes):\n",
    "    print(f'  {cls}: {class_counts[i]} ({class_counts[i]/len(y_train):.2%})')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "xgb-baseline-md",
   "metadata": {},
   "source": [
    "## 3. XGBoost — Baseline Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "xgb-baseline",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "XGBoost Baseline — Accuracy: 0.3766 | Macro ROC-AUC: 0.4689 | Log-Loss: 1.1796\n",
      "\n",
