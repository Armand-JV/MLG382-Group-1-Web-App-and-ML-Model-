    "df     = load_data()\n",
    "result = run_pipeline(df)\n",
    "\n",
    "np.random.seed(42)\n",
    "print('All imports successful. XGBoost version:', __import__('xgboost').__version__)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "xgb-data-md",
